#!/bin/bash
# Minecraft RCON helper - run server commands easily
# Usage: ./mc "command" or ./mc for interactive mode

# shellcheck source=/dev/null
source "$HOME/.env"
RCON_PASS="${RCON_PASSWORD:?RCON_PASSWORD not set in ~/.env}"

if [ -z "$1" ]; then
    mcrcon -H localhost -p "$RCON_PASS" -t
else
    mcrcon -H localhost -p "$RCON_PASS" "$*"
fi
