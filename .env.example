# Master credentials for all home services
# Copy this file to ~/.env and fill in the values:
#   cp .env.example ~/.env && chmod 600 ~/.env

# Immich
IMMICH_API_KEY=
IMMICH_DB_PASSWORD=

# Minecraft RCON
RCON_PASSWORD=

# Cloudflare DDNS
CF_API_TOKEN=
CF_ZONE_ID=
CF_RECORD_NAME=

# Other
OPENROUTER_API_KEY=
DISCORD_BOT_TOKEN=
