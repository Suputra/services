#!/bin/bash
# Regenerate the go-links index page

cat > /tmp/golinks-index.html << HTMLEOF
<!DOCTYPE html>
<html>
<head>
    <title>Go-Links</title>
    <style>
        body { font-family: -apple-system, system-ui, sans-serif; max-width: 600px; margin: 50px auto; padding: 20px; }
        h1 { border-bottom: 2px solid #333; padding-bottom: 10px; }
        .link { display: flex; padding: 12px 0; border-bottom: 1px solid #eee; }
        .shortcut { font-weight: bold; width: 120px; }
        .arrow { color: #999; width: 30px; }
        .dest { color: #666; }
        a { color: #0066cc; text-decoration: none; }
        a:hover { text-decoration: underline; }
        .help { margin-top: 30px; padding: 15px; background: #f5f5f5; border-radius: 5px; font-size: 14px; }
        code { background: #e0e0e0; padding: 2px 6px; border-radius: 3px; }
    </style>
</head>
<body>
    <h1>Go-Links</h1>
HTMLEOF

grep -E "^# [a-z0-9-]+\.y " /etc/nginx/sites-available/golinks | while read line; do
    name=$(echo "$line" | sed -n "s/^# \([a-z0-9-]*\)\.y.*/\1/p")
    desc=$(echo "$line" | sed -n "s/.*-> \(.*\)/\1/p")
    [ "$name" != "admin" ] && echo "    <div class=\"link\"><span class=\"shortcut\"><a href=\"http://${name}.y\">${name}.y</a></span><span class=\"arrow\">→</span><span class=\"dest\">${desc}</span></div>"
done >> /tmp/golinks-index.html

cat >> /tmp/golinks-index.html << HTMLEOF
    <div class="help">
        <strong>Usage:</strong> Type <code>y/name</code> in your browser<br><br>
        <strong>Add new:</strong> <code>~/add-link name http://ip:port</code>
    </div>
</body>
</html>
HTMLEOF

sudo mv /tmp/golinks-index.html /etc/nginx/golinks-index.html
echo "Index updated"
