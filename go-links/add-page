#!/bin/bash

if [ $# -lt 1 ]; then
    echo "Usage: add-page <name> [html-file]"
    echo "Example: add-page hello index.html"
    echo "Example: echo '<h1>Hi</h1>' | add-page hello"
    echo ""
    echo "This creates: y/hello -> serves HTML page"
    exit 1
fi

NAME="$1"
HTML_FILE="$2"
DESC="Static page"

CONFIG="/etc/nginx/sites-available/golinks"
PAGE_DIR="/var/www/golinks/pages/${NAME}"

# Check if already exists
if sudo grep -q "server_name ${NAME}.y;" "$CONFIG" 2>/dev/null; then
    echo "Error: ${NAME}.y already exists"
    exit 1
fi

# Create page directory
mkdir -p "$PAGE_DIR"

# Copy or read HTML content
if [ -n "$HTML_FILE" ] && [ -f "$HTML_FILE" ]; then
    cp "$HTML_FILE" "$PAGE_DIR/index.html"
elif [ -n "$HTML_FILE" ]; then
    echo "Error: File not found: $HTML_FILE"
    exit 1
else
    # Read from stdin
    cat > "$PAGE_DIR/index.html"
fi

# Add HTTP server block
sudo sed -i "/# Main redirector/i\\
# ${NAME}.y -> ${DESC}\\
server {\\
    listen 80;\\
    listen [::]:80;\\
    server_name ${NAME}.y;\\
\\
    root ${PAGE_DIR};\\
    index index.html;\\
\\
    location / {\\
        try_files \$uri \$uri/ =404;\\
    }\\
}\\
" "$CONFIG"

# Test nginx config
if ! sudo nginx -t 2>&1 | grep -q "ok"; then
    echo "Error: nginx config invalid, reverting..."
    sudo sed -i "/# ${NAME}.y/,/^}$/d" "$CONFIG"
    rm -rf "$PAGE_DIR"
    exit 1
fi

# Add DNS entry on Pi
ssh pi "sudo sed -i '/y\.lan/s/$/ ${NAME}.y/' /etc/hosts && sudo pihole reloaddns" > /dev/null 2>&1

# Reload nginx
sudo systemctl reload nginx

echo "Added: y/${NAME} -> serves ${PAGE_DIR}/index.html"
